# Site configuration
SITE_URL=https://yourdomain.github.io/daily-newsletter

# Tavily API (for trending topics search — falls back to keyword extraction if not set)
TAVILY_API_KEY=your-tavily-api-key-here

# Groq API (free tier — used for editorial summaries)
GROQ_API_KEY=your-groq-api-key-here

# Set to 1 for debug-level logging
VERBOSE_LOGGING=0
